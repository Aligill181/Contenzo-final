rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Primitives ───────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerified() { return request.auth.token.email_verified == true; }

    // ─── User Rules ───────────────────────────────────────────────────────────
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.role in ['BUYER', 'SELLER']
          && data.walletBalance is number
          && data.walletBalance >= 0
          && data.keys().hasAll(['uid', 'role', 'walletBalance'])
          && data.keys().size() <= 8;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().walletBalance == 0; // Fresh start
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Prevent users from changing their own sensitive fields
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])
        || isAdmin()
      );
    }

    // ─── Listing Rules ────────────────────────────────────────────────────────
    match /listings/{listingId} {
      function isValidListing(data) {
        return isValidId(listingId)
          && data.sellerId == request.auth.uid
          && data.websiteName is string && data.websiteName.size() <= 100
          && data.websiteUrl is string && data.websiteUrl.size() <= 200
          && data.dr is int && data.dr >= 0 && data.dr <= 100
          && data.price is number && data.price >= 0
          && data.type in ['GUEST_POST', 'LINK_INSERTION', 'HOMEPAGE_LINK', 'NICHE_EDIT']
          && data.keys().hasAll(['sellerId', 'websiteName', 'websiteUrl', 'dr', 'price', 'type']);
      }

      allow read: if incoming().isActive == true || isOwner(existing().sellerId) || isAdmin();
      allow list: if resource.data.isActive == true;
      allow create: if isVerified() && isValidListing(incoming());
      allow update: if (isOwner(existing().sellerId) || isAdmin()) && isValidListing(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['websiteName', 'websiteUrl', 'dr', 'price', 'type', 'niche', 'isActive'])
        || isAdmin()
      );
      allow delete: if (isOwner(existing().sellerId) || isAdmin());
    }

    // ─── Order Rules ──────────────────────────────────────────────────────────
    match /orders/{orderId} {
      function isValidOrder(data) {
         return data.buyerId == request.auth.uid // For creation
          || data.sellerId == request.auth.uid // For updates
          || data.buyerId == existing().buyerId; // Sticky ID check
      }

      allow get: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      
      allow create: if isVerified() 
        && incoming().buyerId == request.auth.uid
        && incoming().status == 'PENDING'
        && exists(/databases/$(database)/documents/listings/$(incoming().listingId));

      allow update: if isSignedIn() && (
        // Seller actions: Mark in progress, deliver
        (request.auth.uid == existing().sellerId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'liveUrl']) && incoming().status in ['IN_PROGRESS', 'DELIVERED'])
        || // Buyer actions: Complete, dispute
        (request.auth.uid == existing().buyerId && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['COMPLETED', 'DISPUTED'])
        || isAdmin()
      );
    }

    match /inquiries/{inquiryId} {
      allow create: if true; // Public contact form
      allow read, write: if isAdmin();
    }
  }
}
